# Proje kökünde ".env" olarak kopyalayın (sunucuda):
#   cp deploy/env.root.example .env && nano .env
#
# Bu dosya: docker compose -f docker-compose.prod.yml için değişken yerleştirme.
# Django / Postgres / SECRET_KEY → .env.production

# Zorunlu: Kullanıcıların tarayıcıda gördüğü adres (Nginx dış portu ile aynı)
NEXT_PUBLIC_API_URL=http://13.217.122.200:8080

# İsteğe bağlı — dışarıda hangi portta yayın (varsayılan 8080)
# NGINX_HOST_PORT=8080

# İsteğe bağlı — harici Postgres kullanıyorsanız .env.production + burada POSTGRES_HOST
# POSTGRES_HOST=your-rds.region.rds.amazonaws.com

# İsteğe bağlı — konteyner dışında Ollama erişimi (varsayılan 11434)
# OLLAMA_HOST_PORT=11434
