# --- Kopyala: ../.env.production (repoda yok, .gitignore) ---
# docker-compose.prod.yml veya AWS task definition ile kullanın.
#
# Tek sunucuda docker-compose.prod.yml: compose backend zaten db + ollama servislerine bağlanır.
# Aşağıdaki POSTGRES_HOST / OLLAMA satırları isteğe bağlı; yorumda bırakırsanız compose varsayılanı (db, http://ollama:11434) kullanılır.
# Harici RDS için proje KÖKÜNDEKİ .env dosyasında POSTGRES_HOST=... tanımlayın (compose interpolasyonu).

# Django
DEBUG=False
SECRET_KEY=replace-with-long-random-string
# 127.0.0.1,localhost: Docker HEALTHCHECK ve sunucuda curl (zorunlu değil dış erişim için; iç kontroller için ekleyin).
# Canlı domain + public IP; ALB kullanıyorsanız elb hostname'ini de virgülle ekleyin.
ALLOWED_HOSTS=127.0.0.1,localhost,www.acusmartassistant.com.tr,acusmartassistant.com.tr
# HTTPS hazır olunca (ACM + load balancer) şu iki satırı açın; HTTP ile test ediyorsanız http:// kullanın.
CSRF_TRUSTED_ORIGINS_EXTRA=https://www.acusmartassistant.com.tr,https://acusmartassistant.com.tr
CORS_ALLOWED_ORIGINS_EXTRA=https://www.acusmartassistant.com.tr,https://acusmartassistant.com.tr
# Geçici olarak sadece IP ile test: önceki iki satırı yorumlayıp aşağıdakileri kullanın.
# CSRF_TRUSTED_ORIGINS_EXTRA=http://SUNUCU_IP:8080
# CORS_ALLOWED_ORIGINS_EXTRA=http://SUNUCU_IP:8080
# WhiteNoise: auto = DEBUG kapalıyken açılır. Zorla kapatmak için DJANGO_WHITENOISE=0
# DJANGO_WHITENOISE=auto

# Postgres konteyneri bu değerleri okur; backend ile aynı olmalı.
POSTGRES_DB=acu_chatbot
POSTGRES_USER=acu
POSTGRES_PASSWORD=replace-me
# Tek sunucuda compose: bu satırı yorumda bırakın (backend `db` servisine bağlanır).
# Harici RDS: burayı açın ve proje kökü PROJECT/.env içinde aynı POSTGRES_HOST ile compose kullanın.
# POSTGRES_HOST=your-rds.region.rds.amazonaws.com
POSTGRES_PORT=5432

# İlk kurulum / tek replika: backend konteynerinde RUN_MIGRATIONS=1 (compose override veya ECS env)
# RUN_MIGRATIONS=1

# OLLAMA_BASE_URL=http://your-ollama-host:11434
OLLAMA_MODEL=llama3.2:3b
# OLLAMA_NUM_PREDICT=384
# OLLAMA_NUM_CTX=8192
# OLLAMA_HTTP_TIMEOUT=120

# Log
# LOG_LEVEL=INFO

# --- Frontend build (NEXT_PUBLIC_API_URL): kullanıcıların göreceği kök adres ---
# docker compose build için bu satırı proje KÖKÜNDEKİ .env dosyasına da yazın (veya kabukta export edin).
# GitHub Actions “Variables” içinde de aynı değer: https://www.acusmartassistant.com.tr
NEXT_PUBLIC_API_URL=https://www.acusmartassistant.com.tr
# Yerelde veya IP ile test: http://localhost:8080 veya http://SUNUCU_IP:8080
# NGINX_HOST_PORT=80
