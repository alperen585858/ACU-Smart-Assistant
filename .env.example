# Copy to .env and adjust. Do not commit .env to version control.
#
# Local dev without Docker: Django reads THIS file from the Project/ root (not backend/).
# You need real PostgreSQL + pgvector. SQLite is not supported in this project.
#
# Same database for everyone: if you run `python manage.py shell` or `runserver` locally
# but the browser talks to Django inside Docker, those processes must use the same
# POSTGRES_HOST / POSTGRES_PORT / database name — otherwise Page/DocumentChunk counts
# and chat RAG will disagree. Docker Compose defaults map host port 5433 to `db:5432`.
# Ollama: install from ollama.com, run `ollama pull llama3.2:3b`, keep `ollama serve` running.
#
# --- PostgreSQL ---
POSTGRES_USER=acu
POSTGRES_PASSWORD=change-me
POSTGRES_DB=acu_chatbot
POSTGRES_HOST=localhost
#
# Port depends on setup:
# - Local Postgres: usually 5432
# - Docker Compose (this repo maps host port): default POSTGRES_HOST_PORT=5433 → use POSTGRES_PORT=5433 here when connecting from the host
POSTGRES_PORT=5432
#
# Optional: override published DB port in docker compose (default 5433)
# POSTGRES_HOST_PORT=5433

# Django (production: set strong SECRET_KEY and real ALLOWED_HOSTS)
# SECRET_KEY=generate-a-secret-key
# ALLOWED_HOSTS=localhost,127.0.0.1,backend

# OLLAMA_BASE_URL=http://127.0.0.1:11434
# docker compose ile backend: varsayılan http://host.docker.internal:11434 (Mac’te Ollama uygulaması).
# Ollama’yı Docker’da istiyorsanız: OLLAMA_DOCKER_URL=http://ollama:11434 ve
#   docker compose --profile docker-ollama up -d
# OLLAMA_MODEL=llama3.2:3b
# Custom model with embedded system prompt (build with: ./scripts/build-acu-model.sh)
OLLAMA_MODEL=acu-assistant
# OLLAMA_NUM_PREDICT=384
# OLLAMA_NUM_CTX=8192
# Larger context needed if RAG_MAX_CHARS is high (default ~7k chars ≈ ~2k tokens + system + history)
# Lower = less hallucination on small models (0.0–0.3 typical)
# OLLAMA_TEMPERATURE=0.15
# OLLAMA_TOP_P=0.85
# Long chats: cap messages so system+RAG fits in num_ctx (too small ctx => model ignores CONTEXT)
# CHAT_HISTORY_MAX_MESSAGES=12
# CHAT_MESSAGE_MAX_CHARS=900
# Max size for the last user turn when it includes ===CONTEXT=== (RAG excerpts)
# RAG_USER_BUBBLE_MAX_CHARS=4500
# OLLAMA_HTTP_TIMEOUT=120
#
# Long RAG (faculty inject, >4k context): default was 12k ctx / 900 tokens — very slow on local 3B.
# Caps speed up without changing when the bump applies; raise on a fast GPU if needed.
# OLLAMA_RAG_BUMP_MAX_CTX=8192
# OLLAMA_RAG_BUMP_MAX_PREDICT=640

# Local embedding (English queries; first run may download the model)
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Retry policy: seconds to wait before retrying a failed model load, max attempts
# EMBEDDING_RETRY_COOLDOWN_SECS=300
# EMBEDDING_MAX_RETRIES=3
# RERANKER_RETRY_COOLDOWN_SECS=300
# RERANKER_MAX_RETRIES=3

# Semantic RAG — wider context pulls from more crawled pages (still one prompt limit)
# RAG_MAX_CHARS=7000
# RAG_TOP_K=28
# RAG_VECTOR_FILL_EXTRA=24
# RAG_MAX_CHUNKS_PER_URL=2
# RAG_SNIPPET_CHARS=1100
# RAG_USER_BUBBLE_MAX_CHARS=14000
# RAG_MAX_DISTANCE=0.62
# RAG_RELAX_ON_EMPTY=true
# RAG_KEYWORD_BOOST=true
#
# Recall-oriented RAG (multi-embed merge, wide pool, rerank; optional pg_trgm on PostgreSQL)
# RAG_MULTI_EMBED=true
# RAG_MULTI_EMBED_KEYWORD_LINE=true
# RAG_VECTOR_CANDIDATE_POOL=56
# RAG_CROSS_ENCODER_RERANK=true
# RAG_RERANK_OVERLAP_WEIGHT=0.06
# RAG_LEXICAL_WEIGHT=0.12
# STEM queries: extra effective distance for event/career/news/congress-style sources (sorting)
# RAG_STEM_NOISE_URL_PENALTY=0.14
#
# OBS / curriculum RAG: when strict assembly yields no chunks, inject up to N OBS showPac rows
# RAG_ACADEMIC_OBS_FALLBACK_LIMIT=5
# Merge top cosine hits from obs.acibadem.edu.tr into the vector pool on academic OBS queries (extra DB work)
# RAG_OBS_VECTOR_PREFILTER=false
#
# Parallel OBS fetch after URL discovery: scrape_obs_bologna --fetch-workers (default 3) or refresh_rag --obs-fetch-workers=N
# Max seconds for Selenium driver.get() per page (facAbout can hang without this). Default 25.
# OBS_PAGE_LOAD_TIMEOUT=25
# Max Selenium navigations during URL discovery (dynCon/section queue); default 40. Raise if programmes missing.
# OBS_SECTION_QUEUE_CAP=40
#
# OBS scrape speed (manage.py scrape_obs_bologna / refresh_rag dynCon merge):
# OBS_SHOWPAC_MAX_DYNCON=12
# Parallel dynCon HTTP fetches per programme page (1 = sequential)
# OBS_DYNCON_HTTP_WORKERS=4
# Per-request timeout seconds (lower = fail faster on slow pages)
# OBS_DYNCON_HTTP_TIMEOUT=24
# Selenium index expansion passes (lower = faster URL discovery, may miss deep links)
# OBS_EXPAND_PASSES=12
#
# "Who is {name}?" / "{name} kimdir" — add role-phrase embedding variants + name keyword boost (asymmetric retrieval)
# RAG_WHOIS_QUERY_EXPAND=true
# RAG_WHOIS_EXTRA_EMBEDS=3
#
# Drop sources by URL substring (comma-separated). On by default, blocks only the en international “tuition-fees-and-scholarships” page; RAG_DEFAULT_SOURCE_BLOCKLIST=false leaves only RAG_SOURCE_URL_BLOCKLIST
# RAG_DEFAULT_SOURCE_BLOCKLIST=true
# RAG_SOURCE_URL_BLOCKLIST=https://acibadem.edu.tr/en/international-office/international-students/useful-information/tuition-fees-and-scholarships
#
# Diagnostics: python manage.py rag_diagnose_coverage [--questions-file PATH] [--json-out PATH]
# Index/crawl hints: python manage.py rag_index_audit

# Docker Compose host ports (optional)
# BACKEND_HOST_PORT=8000
# FRONTEND_HOST_PORT=3000
# Frontend → Django (browser): must match BACKEND_HOST_PORT
# NEXT_PUBLIC_API_URL=http://localhost:8000
