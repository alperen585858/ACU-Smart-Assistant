# Copy to .env and adjust. Do not commit .env to version control.
#
# Local dev without Docker: Django reads THIS file from the Project/ root (not backend/).
# You need real PostgreSQL + pgvector; if POSTGRES_USER is unset, Django uses SQLite (RAG breaks).
# Ollama: install from ollama.com, run `ollama pull llama3.2:3b`, keep `ollama serve` running.
#
# --- PostgreSQL ---
POSTGRES_USER=acu
POSTGRES_PASSWORD=change-me
POSTGRES_DB=acu_chatbot
POSTGRES_HOST=localhost
#
# Port depends on setup:
# - Local Postgres: usually 5432
# - Docker Compose (this repo maps host port): default POSTGRES_HOST_PORT=5433 → use POSTGRES_PORT=5433 here when connecting from the host
POSTGRES_PORT=5432
#
# Optional: override published DB port in docker compose (default 5433)
# POSTGRES_HOST_PORT=5433

# Django (production: set strong SECRET_KEY and real ALLOWED_HOSTS)
# SECRET_KEY=generate-a-secret-key
# ALLOWED_HOSTS=localhost,127.0.0.1,backend

# LLM_BACKEND=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_NUM_PREDICT=384
# OLLAMA_NUM_CTX=8192
# Larger context needed if RAG_MAX_CHARS is high (default ~7k chars ≈ ~2k tokens + system + history)
# Lower = less hallucination on small models (0.0–0.3 typical)
# OLLAMA_TEMPERATURE=0.15
# OLLAMA_TOP_P=0.85
# Long chats: cap messages so system+RAG fits in num_ctx (too small ctx => model ignores CONTEXT)
# CHAT_HISTORY_MAX_MESSAGES=12
# CHAT_MESSAGE_MAX_CHARS=900
# Max size for the last user turn when it includes ===CONTEXT=== (RAG excerpts)
# RAG_USER_BUBBLE_MAX_CHARS=4500
# OLLAMA_HTTP_TIMEOUT=120
#
# LLM_BACKEND=claude
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# Local embedding (English queries; first run may download the model)
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Semantic RAG — wider context pulls from more crawled pages (still one prompt limit)
# RAG_MAX_CHARS=7000
# RAG_TOP_K=28
# RAG_VECTOR_FILL_EXTRA=24
# RAG_MAX_CHUNKS_PER_URL=2
# RAG_SNIPPET_CHARS=1100
# RAG_USER_BUBBLE_MAX_CHARS=14000
# RAG_MAX_DISTANCE=0.62
# RAG_RELAX_ON_EMPTY=true
# RAG_KEYWORD_BOOST=true
#
# Recall-oriented RAG (multi-embed merge, wide pool, rerank; optional pg_trgm on PostgreSQL)
# RAG_MULTI_EMBED=true
# RAG_MULTI_EMBED_KEYWORD_LINE=true
# RAG_VECTOR_CANDIDATE_POOL=100
# RAG_RERANK_OVERLAP_WEIGHT=0.06
# RAG_LEXICAL_WEIGHT=0.12
# STEM queries: extra effective distance for event/career/news/congress-style sources (sorting)
# RAG_STEM_NOISE_URL_PENALTY=0.14
#
# Diagnostics: python manage.py rag_diagnose_coverage [--questions-file PATH] [--json-out PATH]
# Index/crawl hints: python manage.py rag_index_audit

# Docker Compose host ports (optional)
# BACKEND_HOST_PORT=8000
# FRONTEND_HOST_PORT=3000
# Frontend → Django (browser): must match BACKEND_HOST_PORT
# NEXT_PUBLIC_API_URL=http://localhost:8000
