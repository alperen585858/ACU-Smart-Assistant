# PostgreSQL (used by docker-compose and Django when running with DB in Docker)
POSTGRES_USER=acu
POSTGRES_PASSWORD=acu_secret
POSTGRES_DB=acu_chatbot
POSTGRES_HOST=localhost
# Docker compose: Postgres host portu varsayılan 5433 (5432 meşgulse). Konteyner içi backend → db:5432 (değişmez).
# POSTGRES_HOST_PORT=5433
# Django’yu host’tan Docker DB’ye bağlarken: POSTGRES_PORT=5433
POSTGRES_PORT=5432

# Sohbetler: Django chat uygulaması → PostgreSQL (chat_chatsession, chat_chatmessage).
# docker compose: backend migrate ile tablolar oluşur. Yerel SQLite kullanıyorsanız: python manage.py migrate

# Django (optional; for Docker or production)
# SECRET_KEY=your-secret-key-here
# ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Ollama (Django backend bu adres üzerinden modele yazar)
# Docker içinde: http://ollama:11434 — yerelde Ollama: http://127.0.0.1:11434
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# Ollama modeli (phi3:mini ~3.5 GiB+ RAM; Docker Desktop → Resources → Memory artırın)
# OLLAMA_MODEL=phi3:mini
# Üretim sınırı (CPU’da saatler sürmemesi için); daha hızlı: 128
# OLLAMA_NUM_PREDICT=256
# OLLAMA_NUM_CTX=2048
# OLLAMA_HTTP_TIMEOUT=180

# Docker host portları (çakışma olursa değiştir; 8000/3000 meşgulsa ör. 8001 / 3001)
# BACKEND_HOST_PORT=8000
# FRONTEND_HOST_PORT=3001
# Frontend → Django API (tarayıcı; BACKEND_HOST_PORT değiştiyse burayı da güncelle)
# NEXT_PUBLIC_API_URL=http://localhost:8000
